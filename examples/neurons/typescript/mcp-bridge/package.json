{
  "name": "neuron-example-mcp-bridge",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript neuron that bridges MCP servers from a JSON catalog into neuron capabilities (stdio/http; none/bearer/oauth)",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node --import tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@holokai/neuron-sdk": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
